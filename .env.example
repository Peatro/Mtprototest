DB_URL=jdbc:postgresql://localhost:5432/mtproto_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

APP_ADMIN_ENABLED=true
APP_ADMIN_HEADER_NAME=X-Admin-Key
APP_ADMIN_KEY=change-me

APP_STARTUP_BOOTSTRAP_ENABLED=true
APP_STARTUP_CHECK_BATCH_SIZE=120
APP_STARTUP_DEEP_PROBE_LIMIT=10

APP_CHECKER_BATCH_SIZE=200
APP_CHECKER_DEEP_PROBE_LIMIT=20
APP_CHECKER_EXECUTOR_EFFECTIVE_CONCURRENCY=24
APP_CHECKER_EXECUTOR_SUBMISSION_WINDOW_SIZE=24

APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_PUBLIC_READ_LIMIT=120
APP_RATE_LIMIT_FEEDBACK_WRITE_LIMIT=20

MANAGEMENT_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_HEALTH_SHOW_DETAILS=always
SPRINGDOC_SWAGGER_UI_ENABLED=false
SPRINGDOC_API_DOCS_ENABLED=false

POSTGRES_DB=mtproto_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
